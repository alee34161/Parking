# Backend Environment Variables
# SECURITY: Never commit this file to version control!
# INSTRUCTIONS: 
# 1. Copy this file and rename it to .env (with the dot at the beginning)
# 2. Fill in your actual values below
# 3. Add .env to your .gitignore file

# Server Configuration
NODE_ENV=development
PORT=3001

# Frontend URL (for CORS protection)
# Development:
FRONTEND_URL=http://localhost:5173
# Production (update when deploying):
# FRONTEND_URL=https://yourparkingapp.com

# AWS Aurora Database Configuration
# Get these values from your AWS RDS Aurora cluster
DB_HOST=your-aurora-cluster.cluster-xxxxx.us-west-2.rds.amazonaws.com
DB_USER=admin
DB_PASSWORD=your-secure-password-here
DB_NAME=parking_app
DB_PORT=3306

# Admin API Key (for protected endpoints like /api/parking/refresh)
# Generate a strong random key with this command: openssl rand -hex 32
# Or use an online generator: https://www.random.org/strings/
ADMIN_API_KEY=your-secret-admin-key-here

# Scraping Configuration
SCRAPE_INTERVAL_MINUTES=1

# Optional: AWS Configuration (only if using other AWS services like S3)
# AWS_REGION=us-west-2
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# Rate Limiting (optional - defaults are set in server.js)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100

VITE_MAPBOX_TOKEN=your-mapbox-key
VITE_API_URL=http://localhost:3001/api
